<%- include('partials/header') %>

    <div class="container my-5 pt-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="bg-primary py-5 text-center">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=<%= user.name %>"
                            class="rounded-circle border bg-white mb-3" width="120">
                        <h3 class="text-white fw-bold mb-0">
                            <%= user.name %>
                        </h3>
                        <p class="text-white opacity-75 mb-0">
                            <%= user.role.toUpperCase() %> Account
                        </p>
                    </div>
                    <div class="card-body p-5">
                        <div class="row g-4">
                            <div class="col-md-6 border-end border-light">
                                <h6 class="text-muted small fw-bold text-uppercase mb-3">Contact Information</h6>
                                <div class="mb-3">
                                    <label class="small text-muted d-block">Email Address</label>
                                    <span class="fw-bold">
                                        <%= user.email %>
                                    </span>
                                </div>
                                <div class="mb-3">
                                    <label class="small text-muted d-block">Phone Number</label>
                                    <span class="fw-bold">
                                        <%= user.contact || 'Not provided' %>
                                    </span>
                                </div>
                            </div>
                            <div class="col-md-6 ps-md-4">
                                <h6 class="text-muted small fw-bold text-uppercase mb-3">Shipping Address</h6>
                                <p class="fw-bold">
                                    <%= user.address || 'Address not yet registered in your profile.' %>
                                </p>
                            </div>
                        </div>

                        <hr class="my-5 border-light">

                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">Security & Settings</h6>
                            <button class="btn btn-outline-primary btn-sm rounded-pill px-4"
                                onclick="alert('Update Profile feature coming soon!')">Update Profile</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>