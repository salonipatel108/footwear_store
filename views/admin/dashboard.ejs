<%- include('../partials/admin_header', { title: 'Dashboard' , active: 'dashboard' }) %>

    <div class="row g-4">
        <div class="col-xl-3 col-sm-6">
            <div class="card bg-white border-0 h-100">
                <div class="stat-card">
                    <div class="icon-circle bg-accent-soft">
                        <i class="fas fa-box"></i>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold">
                            <%= productCount %>
                        </h5>
                        <p class="text-muted small mb-0">Total Products</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="card bg-white border-0 h-100">
                <div class="stat-card">
                    <div class="icon-circle bg-success-soft">
                        <i class="fas fa-list"></i>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold">
                            <%= categoryCount %>
                        </h5>
                        <p class="text-muted small mb-0">Categories</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="card bg-white border-0 h-100">
                <div class="stat-card">
                    <div class="icon-circle bg-warning-soft">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold">
                            <%= orderCount %>
                        </h5>
                        <p class="text-muted small mb-0">Total Orders</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="card bg-white border-0 h-100">
                <div class="stat-card">
                    <div class="icon-circle bg-info-soft">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold">$<%= totalSales.toFixed(2) %>
                        </h5>
                        <p class="text-muted small mb-0">Total Revenue</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-8">
            <div class="card border-0 h-100 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold mb-0">Recently Added Footwear</h6>
                    <a href="/admin/products" class="btn btn-sm btn-link text-decoration-none">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="text-muted small text-uppercase">
                            <tr>
                                <th class="border-0 px-0">Product Info</th>
                                <th class="border-0">Category</th>
                                <th class="border-0">Price</th>
                                <th class="border-0">Inventory</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            <% recentProducts.forEach(p=> { %>
                                <tr>
                                    <td class="px-0 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-light rounded-3"
                                                style="width: 48px; height: 48px; padding: 2px;">
                                                <% if (p.image && p.image.startsWith('data:image')) { %>
                                                    <img src="<%= p.image %>" class="rounded-3 w-100 h-100"
                                                        style="object-fit: contain;">
                                                    <% } else { %>
                                                        <img src="/uploads/<%= p.image %>" class="rounded-3 w-100 h-100"
                                                            style="object-fit: contain;">
                                                        <% } %>
                                            </div>
                                            <div>
                                                <div class="fw-bold">
                                                    <%= p.title %>
                                                </div>
                                                <div class="text-muted small">
                                                    <%= p.brand %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark fw-500 rounded-pill px-3">
                                            <%= p.category ? p.category.name : 'Uncategorized' %>
                                        </span>
                                    </td>
                                    <td class="fw-bold text-dark">$<%= p.price %>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                <div class="progress-bar bg-primary" style=<%- '"width:' +
                                                    Math.min(p.stock, 100) + '%;"' %>></div>
                                            </div>
                                            <span class="small fw-500">
                                                <%= p.stock %>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 p-4 h-100">
                <h6 class="fw-bold mb-4">Quick Actions</h6>
                <div class="d-grid gap-3">
                    <a href="/admin/product/add"
                        class="btn btn-primary d-flex align-items-center justify-content-center gap-2 py-3">
                        <i class="fas fa-plus"></i> Add New Shoe
                    </a>
                    <a href="/admin/categories"
                        class="btn btn-outline-primary d-flex align-items-center justify-content-center gap-2 py-3">
                        <i class="fas fa-tag"></i> Manage Labels
                    </a>
                </div>

                <div class="mt-5 p-4 bg-accent-soft rounded-4 text-center">
                    <div class="icon-circle bg-white mx-auto mb-3">
                        <i class="fas fa-rocket text-primary"></i>
                    </div>
                    <h6 class="fw-bold">Ready for Sale?</h6>
                    <p class="text-muted small">Update your inventory regularly to stay on top of the footwear market.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/admin_footer') %>