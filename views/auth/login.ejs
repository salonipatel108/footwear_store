<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Modern Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #6366f1;
            --secondary-color: #a855f7;
            --bg-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        }

        body {
            background: #f8fafc;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .auth-container {
            display: flex;
            width: 1000px;
            height: 600px;
            background: white;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            position: relative;
        }

        .auth-left {
            flex: 1;
            background: var(--bg-gradient);
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
            position: relative;
        }

        .auth-left::before {
            content: '';
            position: absolute;
            top: -20%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .auth-left h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .auth-right {
            flex: 1;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            margin-bottom: 20px;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            border-color: var(--primary-color);
        }

        .btn-primary {
            background: var(--primary-color);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: #4f46e5;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
        }

        .role-selector {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .role-option {
            flex: 1;
            text-align: center;
            padding: 12px;
            border: 2px solid #f1f5f9;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
        }

        .role-option i {
            font-size: 1.2rem;
            margin-bottom: 5px;
            display: block;
        }

        .role-option input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }

        .role-option:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .role-option.active {
            border-color: var(--primary-color);
            background: rgba(99, 102, 241, 0.05);
            color: var(--primary-color);
        }

        .social-login {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        .social-btn {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 10px;
            text-align: center;
            color: #475569;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .social-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        @media (max-width: 992px) {
            .auth-container {
                width: 95%;
                height: auto;
                flex-direction: column;
            }

            .auth-left {
                display: none;
            }

            .auth-right {
                padding: 40px 20px;
            }
        }
    </style>
</head>

<body>

    <div class="auth-container">
        <div class="auth-left">
            <div>
                <h1>Modern<br>Shoe Store</h1>
                <p class="lead">Step into style with the most premium collection of footwear.</p>
            </div>
            <div style="margin-top: auto;">
                <p class="small opacity-75">© 2026 Footwear Store Inc.</p>
            </div>
        </div>
        <div class="auth-right">
            <% if (typeof query !=='undefined' && query.registered) { %>
                <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i> Registration successful! Please login.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                    <h2 class="fw-bold mb-2">Welcome Back</h2>
                    <p class="text-muted mb-4">Please enter your details to sign in.</p>

                    <form action="/auth/login" method="POST">

                        <label class="form-label small fw-bold text-muted">SIGN IN AS</label>
                        <div class="role-selector">
                            <label class="role-option active" id="userRole">
                                <i class="fa-solid fa-user"></i>
                                Customer
                                <input type="radio" name="role" value="user" checked onclick="selectRole('user')">
                            </label>
                            <label class="role-option" id="adminRole">
                                <i class="fa-solid fa-user-shield"></i>
                                Administrator
                                <input type="radio" name="role" value="admin" onclick="selectRole('admin')">
                            </label>
                        </div>

                        <div class="mb-1">
                            <label class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                            <input type="email" name="email" class="form-control" placeholder="name@example.com"
                                required>
                        </div>

                        <div class="mb-1">
                            <div class="d-flex justify-content-between">
                                <label class="form-label small fw-bold text-muted">PASSWORD</label>
                                <a href="#" class="small text-decoration-none">Forgot?</a>
                            </div>
                            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-2">Sign In</button>

                        <div class="text-center mt-4">
                            <p class="small text-muted">Don't have an account? <a href="/auth/register"
                                    class="fw-bold text-decoration-none" style="color: var(--primary-color)">Create
                                    account</a>
                            </p>
                        </div>
                    </form>
        </div>
    </div>

    <script>
        function selectRole(role) {
            document.querySelectorAll('.role-option').forEach(opt => opt.classList.remove('active'));
            if (role === 'user') {
                document.getElementById('userRole').classList.add('active');
            } else {
                document.getElementById('adminRole').classList.add('active');
            }
        }
    </script>
</body>

</html>