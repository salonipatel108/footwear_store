<%- include('../partials/admin_header', { title: 'Revise Product' , active: 'products' }) %>

    <div class="row justify-content-center">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm p-4 p-md-5">
                <div class="text-center mb-5">
                    <div class="icon-circle bg-success-soft mx-auto mb-3"
                        style="width: 80px; height: 80px; font-size: 2rem;">
                        <i class="fas fa-edit"></i>
                    </div>
                    <h4 class="fw-bold">Update Inventory Item</h4>
                    <p class="text-muted">Modify the existing specifications for the selected footwear.</p>
                </div>

                <form action="/admin/product/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold small text-muted text-uppercase">Product Title</label>
                            <input type="text" name="title"
                                class="form-control form-control-lg bg-light border-0 rounded-4 px-4" required
                                value="<%= product.title %>">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Brand Name</label>
                            <input type="text" name="brand"
                                class="form-control form-control-lg bg-light border-0 rounded-4 px-4"
                                value="<%= product.brand %>">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Listing Category</label>
                            <select name="category" id="categorySelect"
                                class="form-select form-control-lg bg-light border-0 rounded-4 px-4" required>
                                <option value="">Choose...</option>
                                <% categories.forEach(c=> { %>
                                    <option value="<%= c._id %>" <%=(product.category &&
                                        product.category.toString()===c._id.toString()) ? 'selected' : '' %>><%= c.name
                                            %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Subcategory</label>
                            <select name="subcategory" id="subcategorySelect"
                                class="form-select form-control-lg bg-light border-0 rounded-4 px-4">
                                <option value="">Choose Subcategory...</option>
                                <% subcategories.forEach(s=> { %>
                                    <option value="<%= s._id %>" data-category="<%= s.category %>"
                                        <%=(product.subcategory && product.subcategory.toString()===s._id.toString())
                                        ? 'selected' : '' %>>
                                        <%= s.name %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Selling Price ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 rounded-start-4 ps-4">$</span>
                                <input type="number" step="0.01" name="price"
                                    class="form-control form-control-lg bg-light border-0 rounded-end-4 px-3" required
                                    value="<%= product.price %>">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Current Stock</label>
                            <input type="number" name="stock"
                                class="form-control form-control-lg bg-light border-0 rounded-4 px-4" required
                                value="<%= product.stock %>">
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold small text-muted text-uppercase">Product Narrative</label>
                            <textarea name="description" class="form-control bg-light border-0 rounded-4 px-4 py-3"
                                rows="5"><%= product.description %></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold small text-muted text-uppercase">Product Media</label>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="bg-light p-3 rounded-4 border border-light text-center h-100">
                                        <p class="small text-muted mb-2">Current Image</p>
                                        <img src="/uploads/<%= product.image %>"
                                            class="rounded-3 shadow-sm border w-100 h-100"
                                            style="object-fit: contain; max-height: 120px;">
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div
                                        class="p-4 border-2 border-dashed border-light rounded-4 text-center bg-light-subtle h-100 d-flex flex-column justify-content-center">
                                        <i class="fas fa-sync-alt text-muted mb-2"></i>
                                        <input type="file" name="image"
                                            class="form-control border-0 bg-transparent shadow-none px-0">
                                        <p class="text-muted small mt-2 mb-0">Select a new file if you wish to change
                                            the product display image.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-end mt-5">
                        <a href="/admin/products" class="btn btn-light px-4 py-3 rounded-4 fw-bold">Cancel Update</a>
                        <button type="submit" class="btn btn-primary px-5 py-3 rounded-4 shadow-sm">
                            <i class="fas fa-check-circle me-2"></i> Update Listing
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const catSelect = document.getElementById('categorySelect');
            const subSelect = document.getElementById('subcategorySelect');
            if (catSelect && subSelect) {
                const allSubOptions = Array.from(subSelect.options).filter(opt => opt.value !== "");
                // preserve initial selection
                let currentSubVal = subSelect.value;

                function filterSubcategories() {
                    const catId = catSelect.value;
                    const valToKeep = subSelect.value || currentSubVal;
                    // Keep only the 'Choose...' placeholder and matching options
                    subSelect.innerHTML = '<option value="">Choose Subcategory...</option>';
                    let optionExists = false;
                    allSubOptions.forEach(opt => {
                        if (opt.dataset.category === catId) {
                            subSelect.appendChild(opt);
                            if (opt.value === valToKeep) optionExists = true;
                        }
                    });
                    if (optionExists) {
                        subSelect.value = valToKeep;
                        currentSubVal = valToKeep;
                    } else {
                        currentSubVal = "";
                    }
                }
                catSelect.addEventListener('change', filterSubcategories);
                filterSubcategories(); // run immediately to hide non-matching
            }
        });
    </script>
    <%- include('../partials/admin_footer') %>