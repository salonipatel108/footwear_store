<%- include('partials/header') %>

    <div class="container my-5 py-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <span class="text-primary fw-bold text-uppercase small">Get in Touch</span>
                <h1 class="display-5 fw-bold mb-4">We're Here to Help You</h1>
                <p class="text-muted mb-5">Have questions about our collection, sizing, or your order? Fill out the form
                    below or reach out to us directly.</p>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary-subtle text-primary rounded-circle p-3 me-3">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Email Us</h6>
                        <p class="text-muted small mb-0">support@footwearx.com</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-success-subtle text-success rounded-circle p-3 me-3">
                        <i class="fas fa-phone"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Call Us</h6>
                        <p class="text-muted small mb-0">+91 98765 43210</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-lg rounded-5 p-5">
                    <form onsubmit="event.preventDefault(); alert('Message sent! We will get back to you soon.')">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Full Name</label>
                            <input type="text" class="form-control rounded-3 py-2" placeholder="Your Name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email Address</label>
                            <input type="email" class="form-control rounded-3 py-2" placeholder="name@example.com"
                                required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Message</label>
                            <textarea class="form-control rounded-3 py-2" rows="4" placeholder="How can we help?"
                                required></textarea>
                        </div>
                        <button class="btn btn-primary w-100 rounded-pill py-3 fw-bold">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>