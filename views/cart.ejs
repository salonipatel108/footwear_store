<%- include('partials/header') %>

  <div class="container my-5 py-4">
    <div class="d-flex align-items-center gap-3 mb-5">
      <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
        style="width: 50px; height: 50px;">
        <i class="fas fa-shopping-basket fa-lg"></i>
      </div>
      <h2 class="fw-bold mb-0">Your Selection</h2>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div id="cartItems" class="bg-white rounded-4 shadow-sm p-2">
          <!-- Cart items will be loaded here via JS -->
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
          <h5 class="fw-bold mb-4">Payment Summary</h5>

          <div class="d-flex justify-content-between mb-3 text-muted">
            <span>Subtotal</span>
            <span id="itemsSubtotal">$0.00</span>
          </div>
          <div class="d-flex justify-content-between mb-3 text-muted">
            <span>Shipping Cost</span>
            <span class="text-success">FREE</span>
          </div>
          <hr class="my-4 border-light">
          <div class="d-flex justify-content-between mb-4">
            <span class="h5 fw-bold mb-0">Total Due</span>
            <span id="totalPrice" class="h5 fw-bold text-primary mb-0">$0.00</span>
          </div>

          <button class="btn btn-primary w-100 py-3 rounded-4 shadow-sm fw-bold uppercase letter-spacing-1 mb-3"
            onclick="checkout()">
            Complete Purchase <i class="fas fa-arrow-right ms-2"></i>
          </button>

          <div class="text-center">
            <img src="https://help.zazzle.com/hc/article_attachments/360010513393/Logos-01.png" height="25"
              class="opacity-50 grayscale">
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let cart = JSON.parse(localStorage.getItem('cart')) || [];
    updateCartDisplay();

    function updateCartDisplay() {
      const itemsDiv = document.getElementById('cartItems');
      const totalPrice = document.getElementById('totalPrice');
      const subtotalPrice = document.getElementById('itemsSubtotal');
      const navCartCount = document.getElementById('cartCount');

      if (cart.length === 0) {
        itemsDiv.innerHTML = `
            <div class="text-center py-5">
                <div class="mb-4 text-muted">
                    <i class="fas fa-cart-plus fa-4x opacity-25"></i>
                </div>
                <h4 class="fw-bold">Your cart is feeling light</h4>
                <p class="text-muted">Explore our latest footwear and find your perfect pair.</p>
                <a href="/" class="btn btn-primary rounded-pill px-5 py-2 mt-3">Start Shopping</a>
            </div>
        `;
        totalPrice.innerText = '$0.00';
        subtotalPrice.innerText = '$0.00';
        if (navCartCount) navCartCount.innerText = '0';
        return;
      }

      let html = '';
      let total = 0;
      cart.forEach((item, index) => {
        total += item.price;
        html += `
        <div class="d-flex align-items-center p-4 border-bottom border-light hover-bg-light transition-all">
          <div class="bg-light rounded-3 p-2 me-4" style="width: 80px; height: 80px;">
              <img src="/uploads/${item.image}" class="w-100 h-100" style="object-fit: contain;" onerror="this.src='https://via.placeholder.com/80?text=Shoe'">
          </div>
          <div class="flex-grow-1">
            <h6 class="fw-bold mb-1 text-dark">${item.title}</h6>
            <div class="text-muted small">Premium Edition</div>
            <div class="fw-bold text-primary mt-1">$${item.price}</div>
          </div>
          <div class="ms-3">
              <button class="btn btn-light btn-sm rounded-circle shadow-none border" style="width: 35px; height: 35px;" onclick="removeFromCart(${index})">
                  <i class="fas fa-trash-alt text-danger"></i>
              </button>
          </div>
        </div>
      `;
      });

      itemsDiv.innerHTML = html;
      totalPrice.innerText = '$' + total.toFixed(2);
      subtotalPrice.innerText = '$' + total.toFixed(2);
      if (navCartCount) navCartCount.innerText = cart.length;
    }

    function removeFromCart(index) {
      cart.splice(index, 1);
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartDisplay();
    }

    function checkout() {
      if (cart.length === 0) return alert('Your cart is empty');
      window.location.href = '/orders/checkout';
    }
  </script>

  <style>
    .hover-bg-light:hover {
      background-color: #f8fafc;
    }

    .transition-all {
      transition: 0.3s;
    }

    .grayscale {
      filter: grayscale(1);
    }
  </style>
  <%- include('partials/footer') %>