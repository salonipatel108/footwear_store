<%- include('../partials/admin_header', { title: 'Category Management' , active: 'categories' }) %>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 p-4 sticky-top" style="top: 100px;">
                <h6 class="fw-bold mb-3">Create New Category</h6>
                <form action="/admin/category" method="POST">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted uppercase">Name</label>
                        <input type="text" name="name"
                            class="form-control form-control-lg border-light bg-light rounded-4" required
                            placeholder="e.g. Hiking Boots">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-4 shadow-sm">
                        <i class="fas fa-plus me-2"></i> Save Category
                    </button>
                </form>

                <hr class="my-5 border-light">

                <h6 class="fw-bold mb-3">Add Subcategory</h6>
                <form action="/admin/subcategory" method="POST">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Parent Category</label>
                        <select name="category" class="form-select form-control-lg border-light bg-light rounded-4"
                            required>
                            <option value="">Select Category</option>
                            <% categories.forEach(c=> { %>
                                <option value="<%= c._id %>">
                                    <%= c.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Subcategory Name</label>
                        <input type="text" name="name"
                            class="form-control form-control-lg border-light bg-light rounded-4" required
                            placeholder="e.g. Waterproof">
                    </div>
                    <button type="submit" class="btn btn-dark w-100 py-3 rounded-4 shadow-sm">
                        <i class="fas fa-plus me-2"></i> Save Subcategory
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 p-4">
                <h6 class="fw-bold mb-4">Labels Structure</h6>
                <div class="accordion accordion-flush" id="categoryAccordion">
                    <% categories.forEach((c, index)=> { %>
                        <div class="accordion-item border-0 mb-3 bg-light rounded-4 overflow-hidden">
                            <h2 class="accordion-header">
                                <button
                                    class="accordion-button collapsed bg-transparent py-4 px-4 fw-bold text-dark shadow-none"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                                    <i class="fas fa-folder me-3 text-primary"></i>
                                    <%= c.name %>
                                        <span class="ms-auto badge bg-white text-primary rounded-pill border ms-2">
                                            <%= subcategories.filter(s=> s.category && s.category._id.toString() ===
                                                c._id.toString()).length %> Sub
                                        </span>
                                </button>
                            </h2>
                            <div id="collapse<%= index %>" class="accordion-collapse collapse"
                                data-bs-parent="#categoryAccordion">
                                <div class="accordion-body bg-white border-top border-light px-4">
                                    <div class="list-group list-group-flush">
                                        <% const subs=subcategories.filter(s=> s.category && s.category._id.toString()
                                            === c._id.toString());
                                            if(subs.length > 0) {
                                            subs.forEach(s => {
                                            %>
                                            <div
                                                class="list-group-item d-flex justify-content-between align-items-center py-3 border-light">
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-level-up-alt fa-rotate-90 me-3 text-muted"></i>
                                                    <span class="fw-500">
                                                        <%= s.name %>
                                                    </span>
                                                </div>
                                                <div class="badge bg-light text-muted uppercase small px-2">Sublabel
                                                </div>
                                            </div>
                                            <% }) } else { %>
                                                <div class="text-center py-4 text-muted small">
                                                    No subcategories defined for this group.
                                                </div>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>

                <% if(categories.length===0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-tags fa-3x text-light mb-3"></i>
                        <p class="text-muted">No categories created yet.</p>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/admin_footer') %>