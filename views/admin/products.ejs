<%- include('../partials/admin_header', { title: 'Inventory Management' , active: 'products' }) %>

    <div class="card border-0 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="fw-bold mb-1">Product Catalog</h5>
                <p class="text-muted small mb-0">Total of <%= products.length %> items in stock</p>
            </div>
            <a href="/admin/product/add" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="fas fa-plus-circle"></i> Add New Product
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small text-uppercase">
                        <th class="border-0 rounded-start px-4">Item Details</th>
                        <th class="border-0">Category</th>
                        <th class="border-0">Pricing</th>
                        <th class="border-0">Availability</th>
                        <th class="border-0 rounded-end text-end px-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(p=> { %>
                        <tr>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-light rounded-4 border"
                                        style="width: 60px; height: 60px; padding: 4px; overflow: hidden;">
                                        <% if (p.image && p.image.startsWith('data:image')) { %>
                                            <img src="<%= p.image %>" class="w-100 h-100" style="object-fit: contain;">
                                            <% } else { %>
                                                <img src="/uploads/<%= p.image %>" class="w-100 h-100"
                                                    style="object-fit: contain;">
                                                <% } %>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">
                                            <%= p.title %>
                                        </div>
                                        <div class="text-muted small">Brand: <%= p.brand %>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-accent-soft rounded-pill px-3 py-2">
                                    <%= p.category ? p.category.name : 'N/A' %>
                                </span>
                            </td>
                            <td>
                                <div class="fw-bold text-primary">$<%= p.price %>
                                </div>
                            </td>
                            <td>
                                <% if (p.stock> 10) { %>
                                    <div class="badge bg-success-soft rounded-pill px-3 py-2">
                                        <i class="fas fa-check-circle me-1"></i>
                                        <%= p.stock %> In Stock
                                    </div>
                                    <% } else if (p.stock> 0) { %>
                                        <div class="badge bg-warning-soft rounded-pill px-3 py-2">
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            <%= p.stock %> Low Stock
                                        </div>
                                        <% } else { %>
                                            <div class="badge bg-danger-soft rounded-pill px-3 py-2">
                                                <i class="fas fa-times-circle me-1"></i> Out of Stock
                                            </div>
                                            <% } %>
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-outline-primary btn-sm rounded-3 px-3 text-decoration-none"
                                        href="/admin/product/edit/<%= p._id %>">
                                        <i class="fas fa-edit mb-0"></i> Edit
                                    </a>
                                    <a class="btn btn-outline-danger btn-sm rounded-3 px-3 text-decoration-none"
                                        href="/admin/product/delete/<%= p._id %>"
                                        onclick="return confirm('Full delete this product?')">
                                        <i class="fas fa-trash-alt mb-0"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <%- include('../partials/admin_footer') %>